# Required
API_KEY=your-api-key-here

# Model (download to MODELS_DIR before starting)
MODELS_DIR=./models
MODEL_FILE=Qwen3.6-27B-Q6_K.gguf
MMPROJ_FILE=mmproj-Qwen3.6-27B-BF16.gguf
MODEL_ALIAS=qwen3.6-27b

# Server
PORT=8080
CONTEXT_LENGTH=196608
PARALLEL=3

# KV cache (q8_0 = best quality, q4_0 = max context per GB)
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# Extra llama-server flags (e.g. "--rope-scaling yarn" for extended context)
EXTRA_FLAGS=
